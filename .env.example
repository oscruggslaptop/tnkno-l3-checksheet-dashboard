PORT=4173

# Optional PostgreSQL database mode.
# When DATABASE_URL is set, /api/dashboard reads the latest saved snapshot.
# The app imports from Google Sheets on startup and then on the configured interval.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
IMPORT_INTERVAL_MINUTES=30
IMPORT_SECRET=change-this-secret
ISSUES_PDF_PATH=G:\My Drive\PATHO\L3 Commissioning issues-202606181354.pdf

# Paste the full service account JSON on one line, or paste base64-encoded JSON.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

# JSON array. Each Google Sheet must be shared with the service account email as Viewer.
SHEET_CONFIG=[
  {"group":"PATHO","system":"PS1","sheetId":"GOOGLE_SHEET_ID_FOR_PATHO_PS1","overviewTab":"Overview","sourceFile":"PATHO L3 Checksheet 2026 rev1.4"}
]
